# Chave master para acesso admin (painel e API). Deixe vazia ou "change-me" e rode "npm run ensure-env" para gerar automaticamente.
MASTER_KEY=change-me-to-a-secure-random-key

# URL da Evolution API (rodando no mesmo servidor via Docker)
EVOLUTION_API_URL=http://localhost:8080

# URL pública da Evolution para APIs externas (envio de mensagens). Se não definida, usa EVOLUTION_API_URL. Ex.: http://24.199.99.214:8080 ou https://evolution.seudominio.com
# EVOLUTION_PUBLIC_URL=

# URL base do painel WhatsMont para APIs externas (status/QR). Ex.: http://24.199.99.214:3000 ou https://whatsmont.seudominio.com (usada na tela "Variáveis de conexão")
# WHATSMONT_PUBLIC_URL=

# API Key da Evolution API (enviada ao Docker como AUTHENTICATION_API_KEY). Deixe vazia ou "change-me" e rode "npm run ensure-env" para gerar automaticamente.
EVOLUTION_API_KEY=change-me

# Porta do painel/API
PORT=3000

# Origens CORS permitidas (separadas por vírgula). Ex: http://localhost:3000,https://meudominio.com
CORS_ORIGIN=http://localhost:3000

# Caminho do arquivo SQLite. Use diretório persistente em produção (ex.: /var/lib/whatsmont/data/whatsmont.db) para manter instâncias e tokens após reinício.
DB_PATH=./data/whatsmont.db

# NODE_ENV: development | production
NODE_ENV=development
